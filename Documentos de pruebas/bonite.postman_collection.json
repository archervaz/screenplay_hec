      "name": "Login-paso1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Extraer el woocommerce-login-nonce del HTML\r",
              "var html = pm.response.text();\r",
              "var match = html.match(/name=\"woocommerce-login-nonce\"\\s+value=\"([^\"]+)\"/);\r",
              "\r",
              "if (match) {\r",
              "    pm.collectionVariables.set(\"login_nonce\", match[1]);\r",
              "    console.log(\"✅ login_nonce guardado: \" + match[1]);\r",
              "} else {\r",
              "    console.log(\"❌ No se encontró el woocommerce-login-nonce\");\r",
              "}\r",
              "\r",
              "pm.test(\"Nonce extraído correctamente\", function () {\r",
              "    pm.expect(pm.collectionVariables.get(\"login_nonce\")).to.not.be.undefined;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
