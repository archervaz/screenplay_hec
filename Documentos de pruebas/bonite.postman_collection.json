          "listen": "test",
          "script": {
            "exec": [
              "var html = pm.response.text();\r",
              "var match = html.match(/action=logout[^\"]*_wpnonce=([a-f0-9]+)/);\r",
              "\r",
              "if (match) {\r",
              "    pm.collectionVariables.set(\"logout_nonce\", match[1]);\r",
              "    console.log(\"✅ logout_nonce guardado: \" + match[1]);\r",
              "} else {\r",
              "    console.log(\"❌ No se encontró el _wpnonce de logout (¿login falló?)\");\r",
              "}\r",
              "\r",
              "pm.test(\"Login exitoso - nonce de logout encontrado\", function () {\r",
              "    pm.expect(match).to.not.be.null;\r",
              "});"
            ],
